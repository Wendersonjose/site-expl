# ====================================
# EXPLOSION E-COMMERCE - BACKEND
# Exemplo de variáveis de ambiente
# ====================================
# 1. Copie este arquivo para .env
# 2. Preencha com os valores da sua configuração
# 3. NUNCA commite o arquivo .env
# ====================================

# Servidor
PORT=3000
NODE_ENV=development

# Banco de dados (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=sua_senha
DB_NAME=railway

# Autenticação (JWT)
# Gere uma chave forte com:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=sua_chave_secreta
JWT_EXPIRES_IN=7d

# CORS (origens do frontend, separadas por vírgula: loja e admin)
FRONTEND_URL=http://localhost:5173,http://localhost:5174

# URL da loja (base do link de redefinição de senha)
LOJA_URL=http://localhost:5173

# E-mail (SMTP) — OPCIONAL.
# Sem SMTP_HOST, o "esqueci a senha" entra em modo dev: o link é apenas
# logado no console em vez de enviado por e-mail.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu_email@gmail.com
# SMTP_PASSWORD=sua_senha_de_app
# SMTP_FROM=Explosion <no-reply@explosion.dev>

# Log
LOG_LEVEL=debug
