# ====================================
# EXPLOSION E-COMMERCE - BACKEND
# Arquivo de Exemplo de Variáveis de Ambiente
# ====================================
# 
# INSTRUÇÕES:
# 1. Copie este arquivo e renomeie para .env
# 2. Preencha os valores conforme sua configuração local
# 3. NUNCA commite o arquivo .env no Git!
# 
# ====================================

# ====================================
# CONFIGURAÇÕES DO SERVIDOR
# ====================================

# Porta onde o servidor vai rodar
PORT=3000

# Ambiente de execução (development, production, test)
NODE_ENV=development

# ====================================
# CONFIGURAÇÕES DO BANCO DE DADOS
# ====================================

# Host do banco de dados (localhost para desenvolvimento local)
DB_HOST=localhost

# Porta do PostgreSQL (padrão: 5432)
DB_PORT=5432

# Usuário do PostgreSQL
DB_USER=postgres

# Senha do usuário do PostgreSQL (SUBSTITUA PELA SUA SENHA!)
DB_PASSWORD=sua_senha

# Nome do banco de dados
DB_NAME=explosion_ecommerce

# ====================================
# CONFIGURAÇÕES DE AUTENTICAÇÃO (JWT)
# ====================================

# Chave secreta para assinar tokens JWT
# IMPORTANTE: Use uma string aleatória e complexa
# Para gerar uma chave segura, use:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=sua_chave_secreta

# Tempo de expiração do token
# Exemplos: 1h (1 hora), 7d (7 dias), 30d (30 dias), 1y (1 ano)
JWT_EXPIRES_IN=7d

# ====================================
# CONFIGURAÇÕES DE EMAIL (FUTURO)
# ====================================

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu_email@gmail.com
# SMTP_PASSWORD=sua_senha_de_app

# ====================================
# CONFIGURAÇÕES DE PAGAMENTO (FUTURO)
# ====================================

# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ====================================
# OUTRAS CONFIGURAÇÕES
# ====================================

# URL do frontend (para configuração de CORS)
FRONTEND_URL=http://localhost:5173

# Nível de log (debug, info, warn, error)
LOG_LEVEL=debug
