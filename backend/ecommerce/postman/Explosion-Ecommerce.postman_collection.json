					"name": "List Payment Methods",
					"request": {
						"auth": { "type": "noauth" },
						"method": "GET",
						"header": [],
						"url": { "raw": "{{baseUrl}}/payments/methods", "host": ["{{baseUrl}}"], "path": ["payments", "methods"] },
						"description": "Lista as formas de pagamento ativas (ex.: Pix, Cartão, Boleto).\n\n📖 Público."
					}
				},
				{
					"name": "Pay Order",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"idPedido\": {{lastOrderId}},\n  \"idForma\": 1,\n  \"codigoExterno\": \"PIX-ABC123\"\n}"
						},
						"url": { "raw": "{{baseUrl}}/payments", "host": ["{{baseUrl}}"], "path": ["payments"] },
						"description": "Paga um pedido pendente: cria a transação confirmada e marca o pedido como `pago`.\n\n🔒 Requer autenticação (dono do pedido ou admin)."
					}
				},
				{
					"name": "List Order Payments",
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "{{baseUrl}}/payments/order/{{lastOrderId}}", "host": ["{{baseUrl}}"], "path": ["payments", "order", "{{lastOrderId}}"] },
						"description": "Lista os pagamentos de um pedido.\n\n🔒 Requer autenticação (dono do pedido ou admin)."
					}
				}
			]
		},
