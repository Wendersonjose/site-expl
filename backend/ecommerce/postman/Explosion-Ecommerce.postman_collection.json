{
	"info": {
		"_postman_id": "explosion-ecommerce-api",
		"name": "💥 Explosion E-commerce API",
		"description": "Collection completa da API REST do e-commerce Explosion (Node.js + Express + MySQL).\n\n## 🚀 Como usar\n1. Importe o Environment (`Explosion-Environment.postman_environment.json`).\n2. Confira a variável `baseUrl` (`http://localhost:3000`).\n3. Faça **Auth > Login** — o token JWT é salvo automaticamente em `authToken` e usado nas demais rotas.\n\n## 👤 Perfis\n- **cliente**: faz pedidos, paga e avalia produtos que comprou.\n- **admin**: gestão de produtos, categorias, usuários e relatórios.\n\n> Contas admin não são criadas pelo registro público — use `node scripts/create-admin.js`.\n\n## 📌 Módulos\nAuth · Products · Categories · Orders · Payments · Reviews · Users · Reports",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [{ "key": "token", "value": "{{authToken}}", "type": "string" }]
	},
	"item": [
		{
			"name": "🔐 Auth",
			"description": "Autenticação e registro de usuários.",
			"item": [
				{
					"name": "Register (Cadastro)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 201) {",
									"  const r = pm.response.json();",
									"  if (r.data && r.data.token) {",
									"    pm.environment.set('authToken', r.data.token);",
									"    console.log('✅ Token salvo');",
									"  }",
									"}"
								]
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"nome\": \"João Silva\",\n  \"email\": \"joao@example.com\",\n  \"senha\": \"senha123\"\n}"
						},
						"url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
						"description": "Registra um novo **cliente** e retorna um token JWT.\n\n📖 Público."
					}
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 200) {",
									"  const r = pm.response.json();",
									"  if (r.data && r.data.token) {",
									"    pm.environment.set('authToken', r.data.token);",
									"    console.log('✅ Token salvo | perfil:', r.data.user.perfil);",
									"  }",
									"}"
								]
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"cliente@teste.com\",\n  \"senha\": \"senha123\"\n}"
						},
						"url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
						"description": "Autentica e retorna `{ user, token }`. O token é salvo automaticamente.\n\n📖 Público."
					}
				},
				{
					"name": "Get Me (Verificar Token)",
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] },
						"description": "Retorna os dados do usuário autenticado.\n\n🔒 Requer autenticação."
					}
				}
			]
		},
		{
			"name": "📦 Products",
			"description": "Catálogo de produtos.",
			"item": [
				{
					"name": "List Products",
					"request": {
						"auth": { "type": "noauth" },
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/products?search=&categoria=&ativo=true",
							"host": ["{{baseUrl}}"],
							"path": ["products"],
							"query": [
								{ "key": "search", "value": "", "description": "Busca por nome/descrição" },
								{ "key": "categoria", "value": "", "description": "ID da categoria" },
								{ "key": "ativo", "value": "true", "description": "true/false" }
							]
						},
						"description": "Lista produtos com filtros opcionais.\n\n📖 Público."
					}
				},
				{
					"name": "Get Product by ID",
					"request": {
						"auth": { "type": "noauth" },
						"method": "GET",
						"header": [],
						"url": { "raw": "{{baseUrl}}/products/1", "host": ["{{baseUrl}}"], "path": ["products", "1"] },
						"description": "Busca um produto por ID.\n\n📖 Público."
					}
				},
				{
					"name": "Create Product (admin)",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"nome\": \"Camiseta Explosion\",\n  \"descricao\": \"Camiseta de algodão premium\",\n  \"precoVenda\": 89.90,\n  \"custoUnitario\": 45.00,\n  \"estoque\": 100,\n  \"idCategoria\": 1,\n  \"ativo\": true,\n  \"imagens\": [\n    { \"url\": \"https://example.com/img1.jpg\", \"principal\": true }\n  ]\n}"
						},
						"url": { "raw": "{{baseUrl}}/products", "host": ["{{baseUrl}}"], "path": ["products"] },
						"description": "Cria um produto.\n\n🔒👑 Apenas admin."
					}
				},
				{
					"name": "Update Product (admin)",
					"request": {
						"method": "PUT",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"precoVenda\": 99.90,\n  \"estoque\": 50\n}"
						},
						"url": { "raw": "{{baseUrl}}/products/1", "host": ["{{baseUrl}}"], "path": ["products", "1"] },
						"description": "Atualiza um produto (campos parciais).\n\n🔒👑 Apenas admin."
					}
				},
				{
					"name": "Delete Product (admin)",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": { "raw": "{{baseUrl}}/products/1", "host": ["{{baseUrl}}"], "path": ["products", "1"] },
						"description": "Remove um produto.\n\n🔒👑 Apenas admin."
					}
				}
			]
		},
		{
