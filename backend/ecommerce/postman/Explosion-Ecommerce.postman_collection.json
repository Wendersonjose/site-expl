						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"nomeCategoria\": \"Energéticos\"\n}" },
						"url": { "raw": "{{baseUrl}}/categories", "host": ["{{baseUrl}}"], "path": ["categories"] },
						"description": "Cria uma categoria.\n\n🔒👑 Apenas admin."
					}
				},
				{
					"name": "Delete Category (admin)",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": { "raw": "{{baseUrl}}/categories/1", "host": ["{{baseUrl}}"], "path": ["categories", "1"] },
						"description": "Remove uma categoria.\n\n🔒👑 Apenas admin."
					}
				}
			]
		},
		{
			"name": "🛒 Orders",
			"description": "Pedidos do cliente autenticado.",
			"item": [
				{
					"name": "Create Order",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 201) {",
									"  const r = pm.response.json();",
									"  if (r.data && r.data.id) {",
									"    pm.environment.set('lastOrderId', r.data.id);",
									"    console.log('🛒 Pedido criado:', r.data.id);",
									"  }",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"endereco\": {\n    \"cep\": \"50000-000\",\n    \"rua\": \"Rua das Flores\",\n    \"numero\": \"123\",\n    \"complemento\": \"Apto 45\",\n    \"cidade\": \"Recife\",\n    \"estado\": \"PE\"\n  },\n  \"itens\": [\n    { \"idProduto\": 1, \"quantidade\": 2 }\n  ]\n}"
						},
						"url": { "raw": "{{baseUrl}}/orders", "host": ["{{baseUrl}}"], "path": ["orders"] },
						"description": "Cria um pedido (verifica e baixa o estoque em transação). Salva o id em `lastOrderId`.\n\n🔒 Requer autenticação."
					}
				},
				{
					"name": "List My Orders",
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "{{baseUrl}}/orders", "host": ["{{baseUrl}}"], "path": ["orders"] },
						"description": "Lista os pedidos do usuário autenticado.\n\n🔒 Requer autenticação."
					}
				},
				{
					"name": "Get Order by ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "{{baseUrl}}/orders/{{lastOrderId}}", "host": ["{{baseUrl}}"], "path": ["orders", "{{lastOrderId}}"] },
						"description": "Detalhe de um pedido (dono ou admin).\n\n🔒 Requer autenticação."
					}
				}
			]
		},
		{
			"name": "💳 Payments",
			"description": "Formas de pagamento e pagamento de pedidos.",
			"item": [
